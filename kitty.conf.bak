# BEGIN_KITTY_THEME
# Kaolin Ocean
include current-theme.conf
# END_KITTY_THEME

enable_audio_bell no
# font_family LigaSFMonoNerdFont
font_size 12
repaint_delay 1
confirm_os_window_close -1
window_padding_width 0 3

# BEGIN_KITTY_FONTS
font_family      family='Liga SFMono Nerd Font' postscript_name=LigaSFMonoNerdFont-Regular
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
